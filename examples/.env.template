# @gbg/go-core SDK Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control

# Security Configuration
# The SDK supports loading security credentials from environment variables
# with the prefix: GO_
#
# Security environment variables:
GO_CUSTOMER_ACCESS=your_customeraccess_here

# Debug Configuration
# Enable HTTP request/response logging for debugging
GO_DEBUG=true
